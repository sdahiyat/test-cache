# =============================================================================
# StudySync — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values for your environment.
# NEVER commit .env.local to version control.
#
# Where to find each value:
#   Supabase:  https://app.supabase.com → Project Settings → API
#   OpenAI:    https://platform.openai.com/api-keys
#   Stripe:    https://dashboard.stripe.com/apikeys
#              Stripe webhook secret: https://dashboard.stripe.com/webhooks
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
# Your project's REST/Auth URL (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url

# Anonymous/public key (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Service role key — grants admin access, bypasses RLS.
# NEVER expose this to the browser or commit it to version control.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# -----------------------------------------------------------------------------
# OpenAI
# -----------------------------------------------------------------------------
# Server-side only — used for AI study plan generation and learning tips.
OPENAI_API_KEY=your_openai_api_key

# -----------------------------------------------------------------------------
# Stripe
# -----------------------------------------------------------------------------
# Server-side secret key — used for payment processing and subscription management.
STRIPE_SECRET_KEY=your_stripe_secret_key

# Webhook signing secret — used to verify Stripe webhook payloads.
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# Publishable key (safe to expose to the browser)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
